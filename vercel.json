{
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/chat.ts": { "maxDuration": 300, "includeFiles": "src/**" },
    "api/health.ts": { "maxDuration": 10 },
    "api/data.ts": { "maxDuration": 30, "includeFiles": "src/**" },
    "api/backtest.ts": { "maxDuration": 60, "includeFiles": "src/**" },
    "api/paper-trade.ts": { "maxDuration": 30, "includeFiles": "src/**" },
    "api/line-webhook.ts": { "maxDuration": 10, "includeFiles": "src/**" },
    "api/auto-strategy-config.ts": { "maxDuration": 10, "includeFiles": "src/**" },
    "api/cron/index.ts": { "maxDuration": 60, "includeFiles": "src/**" },
    "api/conversations.ts": { "maxDuration": 10, "includeFiles": "src/**" },
    "api/daily-picks.ts": { "maxDuration": 30, "includeFiles": "src/**" }
  },
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/conversations", "destination": "/api/conversations" },
    { "source": "/api/daily-picks", "destination": "/api/daily-picks" },
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/portfolio", "destination": "/api/data?type=portfolio" },
    { "source": "/api/dividends", "destination": "/api/data?type=dividends" },
    { "source": "/api/watchlist", "destination": "/api/data?type=watchlist" },
    { "source": "/api/snapshots", "destination": "/api/data?type=snapshots" },
    { "source": "/api/tax-goals", "destination": "/api/data?type=tax-goals" },
    { "source": "/api/alert-rules", "destination": "/api/data?type=alert-rules" },
    { "source": "/api/backtest", "destination": "/api/backtest" },
    { "source": "/api/paper-trade", "destination": "/api/paper-trade" },
    { "source": "/api/line-webhook", "destination": "/api/line-webhook" },
    { "source": "/api/auto-strategy-config", "destination": "/api/auto-strategy-config" },
    { "source": "/api/cron/scan-alerts", "destination": "/api/cron?job=scan-alerts" },
    { "source": "/api/cron/snapshot", "destination": "/api/cron?job=snapshot" },
    { "source": "/api/cron/news-alerts", "destination": "/api/cron?job=news-alerts" },
    { "source": "/api/cron/auto-strategy", "destination": "/api/cron?job=auto-strategy" },
    { "source": "/api/cron/economic-alerts", "destination": "/api/cron?job=economic-alerts" },
    { "source": "/api/cron/weekly-report", "destination": "/api/cron?job=weekly-report" },
    { "source": "/api/cron/earnings-calendar", "destination": "/api/cron?job=earnings-calendar" }
  ],
  "crons": [
    {
      "path": "/api/cron/scan-alerts",
      "schedule": "0 7 * * 1-5"
    }
  ]
}
