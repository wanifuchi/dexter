{
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 300,
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/portfolio", "destination": "/api/portfolio" },
    { "source": "/api/dividends", "destination": "/api/dividends" },
    { "source": "/api/snapshots", "destination": "/api/snapshots" },
    { "source": "/api/backtest", "destination": "/api/backtest" },
    { "source": "/api/watchlist", "destination": "/api/watchlist" },
    { "source": "/api/paper-trade", "destination": "/api/paper-trade" },
    { "source": "/api/line-webhook", "destination": "/api/line-webhook" },
    { "source": "/api/auto-strategy-config", "destination": "/api/auto-strategy-config" }
  ],
  "crons": [
    {
      "path": "/api/cron/scan-alerts",
      "schedule": "0 7 * * 1-5"
    }
  ]
}
